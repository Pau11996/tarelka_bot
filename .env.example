# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=taarelka_bot
# Username чата или invite-ссылка: taarelkachat / https://t.me/+...
TELEGRAM_FEEDBACK_CHAT=taarelkachat

# Landing page
LANDING_PORT=8080
LANDING_TITLE=ТАРЕЛКА

# Database
POSTGRES_USER=wellhealth
POSTGRES_PASSWORD=wellhealth
POSTGRES_DB=wellhealth
DATABASE_URL=postgresql+asyncpg://wellhealth:wellhealth@postgres:5432/wellhealth

# AI Analyzer backend: Cursor CLI (default) or OpenAI API
AI_ANALYZER_URL=http://ai_analyzer:8000
# API=true switches ai_analyzer to OpenAI instead of Cursor CLI
API=false
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT=120
# OPENAI_TEMPERATURE=0.2
# If the server is in an unsupported region, route OpenAI traffic through a proxy:
# OPENAI_HTTP_PROXY=http://proxy.example.com:8080

CURSOR_API_KEY=your-cursor-api-key
CURSOR_MODEL=composer-2.5

# Optional: proxy for Cursor CLI inside Docker (corporate networks)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NODE_EXTRA_CA_CERTS=/path/to/corporate-ca.pem

# Optional: default timezone for new users
DEFAULT_TIMEZONE=Europe/Moscow

# Optional: auto-delete transient messages after N seconds (default: 7200)
MESSAGE_CLEANUP_TTL_SECONDS=7200

# Optional: daily AI request limit per user (default: 6)
DAILY_REQUEST_LIMIT=6
